<!DOCTYPE html>
<html lang="en">
<%- include('./layout/head.ejs')  %>
<body>
    <%- include('./layout/nav.ejs')  %>

    <div class="container">
        <div>
            <h1>Edit Post</h1>
            <% if(error){ %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
        </div>

        <div>
                <form action="/posts/<%= post._id %>/edit" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="" class="form-label">Post Image</label>
                        <input type="file" name="image" id="image" class="form-control" accept="image/*">
                    </div>

                    <div class="mb-3">
                        <label for="" class="form-label">Post Title</label>
                        <!-- <input type="text" name="title" id="title" value="<%= post ? post.title : '' %>"> -->
                        <input type="text" name="title" id="title"  class="form-control" value="<%= post.title || '' %>">
                    </div>

                    <div class="mb-3">
                        <label for=" class="form-label"">Post Sub Title</label>
                        <input type="text" name="subtitle" id="subtitle"  class="form-control" value="<%= post ? post.subtitle : '' %>">
                    </div>

                    <div class="mb-3">
                        <label for="body" class="form-label">Body</label>
                        <textarea name="body" id="body"  class="form-control"><%= post ? post.body : '' %></textarea>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="buttons" class="btn btn-primary">Update</button>
                    </div>
                </form>
        </div>
    </div>


    
    <%- include('./layout/footer.ejs')  %>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>