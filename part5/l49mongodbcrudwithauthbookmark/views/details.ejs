<!DOCTYPE html>
<html lang="en">
<%- include('./layout/head.ejs')  %>
<body>
  
    <%- include('./layout/nav.ejs')  %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <% if(post.imageURL){ %>
                            <img src="<%= post.imageURL %>" class="img-fluid mb-3" alt="<%= post.title %>">
                        <% } %>

                        <h3><%= post.title %></h3>

                        <p class="text-muted mb-2">Posted: <%= post.createdAt ? new Date(post.createdAt).toLocaleString() : "Unknown date" %></p>
                        
                        <p class="text-muted mb-2">Readers Online: <span id="viewercounter" class="fw-bold">0</span></p>

                        <h5 class="text-secondary"><%= post.subtitle %></h5>
                        <hr/>

                        <p><%= post.body %></p>
                        
                        <%
                            const currentuserid = currentuser ? currentuser._id : null;
                            const isLiked = currentuserid && post.likes ?  post.likes?.some(id => id.toString() === currentuserid.toString()) : false;
                            const isDisliked = currentuserid && post.dislikes ?  post.dislikes?.some(id => id.toString() === currentuserid.toString()) : false;
                        %>
                        <button type="button" id="likebtn" class="btn btn-sm <%= isLiked ? 'btn-success' : 'btn-outline-success' %> " <%= currentuserid ? "" : "disabled" %>>Like <span id="likecount"><%= post.likes ? post.likes.length : 0 %></span></button>
                        <button type="button" id="dislikebtn" class="btn btn-sm <%= isDisliked ? 'btn-danger' : 'btn-outline-danger' %>"  <%= currentuserid ? "" : "disabled" %>>Disike <span id="dislikecount"><%= post.dislikes ? post.dislikes.length : 0 %></span></button>
                       
                        <%
                            const isBookmarked = currentuserid && post.bookmarks ?  post.bookmarks?.some(id => id.toString() === currentuserid.toString()) : false;
                        %>
                        <button type="button" id="bookmarkbtn" class="btn btn-sm <%= isBookmarked ? 'btn-warning' : 'btn-outline-warning' %>"  <%= currentuserid ? "" : "disabled" %> >
                            <span id="bookmarktext"><%= isBookmarked ? 'Saved' : 'Save'  %></span>
                            <span id="bookmarkcount"><%= post.bookmarks ? post.bookmarks.length : 0 %></span>
                        </button>
                        

                        <div class="d-flex gap-2 mt-4">
                            <a href="/" class="btn btn-outline-secondary">Back</a>
                            <a href="/posts/<%= post._id %>/edit" class="btn btn-primary"><i class="fa-solid fa-pen-to-square"></i></a>
                            <form action="/posts/<%= post._id %>/delete %>" method="POST" onsubmit="return confirm(`Are you sure you want to delete this post?`)">
                                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>

                        
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <hr class="my-8" />

                <h5>Comments</h5>

                <% if(commentError){ %>
                    <div class="alert alert-danger"><%= commentError %></div>
                <% } %>
           
                <% if(currentuser){ %>
                    <form action="/posts/<%= post.slug %>/comments" method="POST" class="mb-4">
                        <div class="mb-2">
                            <textarea name="message" class="form-control" rows="3" placeholder="Write a comment...." ></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary btn-sm">Comment</button>
                        </div>
                    </form>
                <% }else{ %>
                    <p class="text-muted">
                        Please <a href="/login">login</a> to comment.
                    </p>
                <% } %>

                
                <div id="commentsbox">
                    <% if(comments.length > 0){ %>
                        <%comments.forEach(comment=>{ %>
                            <div id="comment-box-<%= comment._id %>" class="border rounded p-2 mb-2">
                                <!-- normal view mode  -->
                                <div id="comment-view-<%= comment._id %>">
                                    <strong><%= comment.name %></strong>
                                    <small class="text-muted"><%= comment.createdAt ? new Date(comment.createdAt).toLocaleString() : "" %></small>
                                    <div id="comment-text-<%= comment._id %>"><%= comment.message %></div>

                                    <% if(currentuser && comment.userId && comment.userId.toString() == currentuser._id){ %>
                                        <div class="d-flex justify-content-end gap-2 mt-2">
                                            <button type="button" class="btn btn-sm btn-primary" onclick="showeditform('<%= comment._id %>')">Edit</button>
                                            <form action="/comments/<%= comment._id %>/delete" method="POST">
                                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>   
                                            </form>
                                        </div>
                                    <% } %>

                                </div>

                                <!-- edit mode -->
                                <% if(currentuser && comment.userId && comment.userId.toString() == currentuser._id){ %>
                                <div id="comment-edit-<%= comment._id %>" class="mt-2" style="display: none;">
                                    <form action="/comments/<%= comment._id %>/edit" method="POST">
                                        <div>
                                            <textarea name="editmessage" id="" class="form-control" rows="2"><%= comment.message %></textarea>
                                        </div>

                                        <div class="d-flex justify-content-end gap-2 mt-2">
                                            <button type="button" class="btn btn-sm btn-secondary" onclick="hideeditform('<%= comment._id %>')">Cancel</button>
                                            <button type="submit" class="btn btn-sm btn-success">Save</button>
                                        </div>
                                    </form>
                                </div>
                                <% } %>

                            </div>

                          
                        <% }) %>

                    <% }else{ %>
                        <p class="text-muted">No comments yet.</p>
                    <% } %>

                </div>
            </div>
        </div>
    </div>
    <%- include('./layout/footer.ejs')  %>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        const ioClient = io();
        const pageslug = "<%= post.slug %>";

        const likebtn = document.getElementById('likebtn');
        const dislikebtn = document.getElementById('dislikebtn');
        const likecount = document.getElementById('likecount');
        const dislikecount = document.getElementById('dislikecount');

        const bookmarkbtn = document.getElementById('bookmarkbtn');
        const bookmarktext = document.getElementById('bookmarktext');
        const bookmarkcount = document.getElementById('bookmarkcount')


        ioClient.emit("join-post",pageslug);

        ioClient.on("post:viewers",(payload)=>{
            if(pageslug != payload.slug) return;

            const viewercounter = document.getElementById('viewercounter');
            if(viewercounter) viewercounter.textContent = payload.count;
        });


        // COMMENT CREATED
        ioClient.on('comments:created',(payload)=>{
            if(pageslug != payload.slug) return;

            const cmtbox = document.getElementById('commentsbox');
            const comment = payload.comment;

            // create new div
            const div = document.createElement('div');
            div.id = `comment-box-${comment._id}`;
            div.className = "border rounded p-2 mb-2"
            div.innerHTML = `
                <div id="comment-view-${comment._id}">
                    <strong>${escapseHtml(comment.name)}</strong>
                    <small class="text-muted">${ new Date(comment.createdAt).toLocaleString() }</small>
                    <div id="comment-text-${comment._id}">${ escapseHtml(comment.message) }</div>
                </div>
            `;

            // add to top (prepend)
            cmtbox.prepend(div);
        });

        // COMMENT updateds
        ioClient.on('comments:updated',(payload)=>{
            const comment = payload.comment;

            const commentText = document.getElementById(`comment-text-${comment._id}`);

            if(commentText){
                commentText.textContent = comment.message;
            }
        });

          // COMMENT deleted
        ioClient.on('comments:deleted',(payload)=>{
            const commentbox = document.getElementById(`comment-box-${payload.commentId}`);
       
            if(commentbox){
                commentbox.remove();
            }
        });


        // pagehide event can also use.
        window.addEventListener('beforeunload',()=>{
            ioClient.emit('leave-post',pageslug);
        });

        // helper
        function escapseHtml(text){
            return String(text)
            .replaceAll("&","&amp;")
            .replaceAll("<","&lt;")
            .replaceAll(">","&gt;")
            .replaceAll('"',"&quot;")
            .replaceAll("'","&#39;");
        }


        // Start comment view/edit mode
        function showeditform(commentid){
            const viewbox = document.getElementById(`comment-view-${commentid}`);
            const editbox = document.getElementById(`comment-edit-${commentid}`);

            if(viewbox) viewbox.style.display = "none";
            if(editbox) editbox.style.display = "block";


        }
        function hideeditform(commentid){
            console.log('hay');
            const viewbox = document.getElementById(`comment-view-${commentid}`);
            const editbox = document.getElementById(`comment-edit-${commentid}`);

            if(viewbox) viewbox.style.display = "block";
            if(editbox) editbox.style.display = "none";
        }
        // End comment view/edit mode

        // Start like/dislike
        // for like btn
        if(likebtn){
            likebtn.addEventListener('click',async ()=>{
                try{
                    const res = await fetch(`/posts/${pageslug}/like`,{
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });

                    const result = await res.json();

                    if(!result.success){
                        alert(result.message || 'Like failed');
                        return;
                    }

                    // likebtn
                    // likecount inc / discount dec
                    // btn-success / btn outline danger

                    updatereaction(result.data);


                }catch(error){
                    console.log("Like error: ",error)
                }
            });
        }


        // for dislike btn
        if(dislikebtn){
            dislikebtn.addEventListener('click',async ()=>{
                try{
                    const res = await fetch(`/posts/${pageslug}/dislike`,{
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });

                    const result = await res.json();

                    if(!result.success){
                        alert(result.message || 'Dislike failed');
                        return;
                    }

                    // dislikebtn
                    // likecount dec / discount inc
                    // btn-outline-success / btn danger
                    updatereaction(result.data);


                }catch(error){
                    console.log("Dislike error: ",error)
                }
            });
        }

        function updatereaction(data){
            if(likecount) likecount.textContent = data.likesCount;
            if(dislikecount) dislikecount.textContent = data.dislikesCount;

            if(likebtn){
                likebtn.classList.remove('btn-success','btn-outline-success');

                if(data.liked){
                    likebtn.classList.add('btn-success');
                }else{
                    likebtn.classList.add('btn-outline-success');
                }
            }

            if(dislikebtn){
                dislikebtn.classList.remove('btn-danger','btn-outline-danger');

                if(data.disliked){
                    dislikebtn.classList.add('btn-danger');
                }else{
                    dislikebtn.classList.add('btn-outline-danger');
                }
            }
        }

        ioClient.on('likedislike:reaction',(payload)=>{
            if(pageslug !== payload.slug) return;
            
            updatereaction(payload);
        })

        // End like/dislike

        // Start Bookmark
        if(bookmarkbtn){
            bookmarkbtn.addEventListener("click",async ()=>{
                try{
                    const res = await fetch(`/posts/${pageslug}/bookmark`,{
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });

                    const result = await res.json();

                    if(!result.success){
                        alert(result.message || 'Bookmark failed');
                        return;
                    }

                    // dislikebtn
                    // likecount dec / discount inc
                    // btn-outline-success / btn danger
                    updatebookmark(result.data);

                }catch(error){
                    console.error("Bookmark error: ", error);
                }
            });
        }

        function updatebookmark(data){
            if(bookmarkcount) bookmarkcount.textContent = data.bookmarksCount;

            if(bookmarktext) bookmarktext.textContent = data.bookmarked ? "Saved" : "Save";

            if(bookmarkbtn){
                bookmarkbtn.classList.remove('btn-warning','btn-outline-warning');

                if(data.bookmarked){
                    bookmarkbtn.classList.add('btn-warning');
                }else{
                    bookmarkbtn.classList.add('btn-outline-warning');
                }
            }
        }

        ioClient.on('bookmarked:reaction',(payload)=>{
            if(pageslug !== payload.slug) return;
            
            updatebookmark(payload);
        })

        // End Bookmark

    </script>
</body>
</html>