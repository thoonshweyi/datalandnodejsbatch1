<!DOCTYPE html>
<html lang="en">
<%- include('./layout/head.ejs')  %>
<body>
  
    <%- include('./layout/nav.ejs')  %>

    <div class="container mt-5">
        <div class="mb-3">
            <div class="row">
                <div class="col-md-8 mb-2 mb-md-0">
                    <h5 class="fw-bold mb-2">
                        <i class="fa-solid fa-chart-line me-2"></i>
                        Live Admin Dashboard
                    </h5>
                </div>

                <div class="col-md-4 text-md-end">
                    <a href="/posts/create" class="btn btn-light btn-sm">
                        <i class="fa-solid fa-plus me-1"></i>
                        Create Post
                    </a>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3 mb-3">
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small text-muted mb-1">Total Posts</p>
                            <h3 id="posts-count" class="fw-bold mb-0"><%= postsCount %></h3>
                        </div>
                        <div>
                            <i class="fa-solid fa-newspaper"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small text-muted mb-1">Total Users</p>
                            <h3 id="users-count" class="fw-bold mb-0"><%= usersCount %></h3>
                        </div>
                        <div>
                            <i class="fa-solid fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small text-muted mb-1">Total Comments</p>
                            <h3 id="comments-count" class="fw-bold mb-0"><%= commentsCount %></h3>
                        </div>
                        <div>
                            <i class="fa-solid fa-comments"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small text-muted mb-1">Total Notifiations</p>
                            <h3 id="notifications-count" class="fw-bold mb-0"><%= notificationsCount %></h3>
                        </div>
                        <div>
                            <i class="fa-solid fa-bell"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 mb-3">
                <div class="card">
                    <div class="card-header border-0 py-3">
                        <h5 class="fw-bold mb-0">
                            <i class="fa-solid fa-fire text-danger me-2"></i> Top Liked Posts
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-response">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Posts</th>
                                        <th>Likes</th>
                                        <th>Dislikes</th>
                                        <th>Saved</th>
                                    </tr>
                                </thead>
                                <tbody id="top-liked-posts-tbody">
                                    <% if(topLikedPosts && topLikedPosts.length > 0){ %>
                                        <% topLikedPosts.forEach(post=>{ %>
                                            <tr>
                                                <td>
                                                    <div><%= post.title %></div>
                                                    <small><%= post.createdAt ? new Date(post.createdAt).toLocaleDateString() : "" %></small>
                                                </td>
                                                <td><%= post.likesCount %></td>
                                                <td><%= post.dislikesCount %></td>
                                                <td><%= post.bookmarksCount %></td>
                                            </tr>
                                        <% }) %>
                                    <% }else{ %>
                                        <tr>
                                            <td colspan="4" class="text-muted">No Posts yet.</td>
                                        </tr>
                                    <% } %>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-header border-0 py-3">
                        <h5 class="fw-bold mb-0">
                            <i class="fa-solid fa-message text-success me-2"></i> Latest Comments
                        </h5>
                    </div>

                    <div id="latest-comment-box" class="card-body">
                        <% if(latestComments && latestComments.length > 0){ %>
                            <% latestComments.forEach(comment=>{ %>
                                <div class="mb-3">
                                    <strong><%= comment.name %></strong>
                                    <p class="small mb-1"><%= comment.message %></p>
                                    <small class="small text-muted  d-block mb-3">
                                        <i class="fa-regular fa-calendar"></i>
                                        <%= comment.createdAt ? new Date(comment.createdAt).toLocaleDateString() : "" %>
                                    </small>
                                </div>
                            <% }) %>
                        <% }else{ %>
                            <p class="text-muted mb-0">No Comments yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header border-0 py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="fa-solid fa-clock text-success me-2"></i> Latest Posts
                    </h5>
                </div>

                <div class="card-body">
                    <div id="latest-posts-box" class="row">
                        <% if(latestPosts && latestPosts.length > 0){ %>
                            <% latestPosts.forEach(post=>{ %>
                                <div class="col-lg-4 col-md-6 mb-3">
                                    <div class="h-100 border rounded-4 p-3 bg-light">
                                        <h6 class="fw-bold"><%= post.title %></h6>
                                        <p class="text-muted mb-2"><%= post.subtitle ? post.subtitle.substring(0,80) : "No subtitle" %></p>
                                        <small class="small text-muted  d-block mb-3">
                                            <i class="fa-regular fa-calendar"></i>
                                            <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString() : "" %>
                                        </small>
                                        <a href="/posts/<%= post.slug %>" class="btn btn-primary btn-sm">Read More</a>
                                    </div>
                                </div>
                            <% }) %>
                        <% }else{ %>
                            <p class="text-muted mb-0">No posts yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('./layout/footer.ejs')  %>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>

        const dashboardSock = io();
        
        dashboardSock.emit("join-dashboard");
        
        dashboardSock.on("dashboard:update",(payload)=>{
            updateDashboardCounts(payload);
            updateLatestPosts(payload.latestPosts);
            updateLatestComments(payload.latestComments);
            updateTopLikedPosts(payload.topLikedPosts);
        });

        function updateDashboardCounts(data){
            console.log(data);
            document.getElementById('posts-count').textContent = data.postsCount;
            document.getElementById('users-count').textContent = data.usersCount;
            document.getElementById('comments-count').textContent = data.commentsCount;
            document.getElementById('notifications-count').textContent = data.notificationsCount;
        }

        function updateLatestPosts(data){
            const postbox = document.getElementById('latest-posts-box');
            if(!postbox) return;

            if(!data || !data.length === 0){
                postbox.innerHTML = `
                    <p class="text-muted mb-0">No posts yet.</p>
                `;
                return;
            }

            postbox.innerHTML = data.map(post=>`
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="h-100 border rounded-4 p-3 bg-light">
                        <h6 class="fw-bold">${ escapseHtml(post.title) }</h6>
                        <p class="text-muted mb-2">${ post.subtitle ? escapseHtml(post.subtitle.substring(0,80)) : "No subtitle" }</p>
                        <small class="small text-muted  d-block mb-3">
                            <i class="fa-regular fa-calendar"></i>
                            ${ post.createdAt ? new Date(post.createdAt).toLocaleDateString() : "" }
                        </small>
                        <a href="/posts/${ post.slug }" class="btn btn-primary btn-sm">Read More</a>
                    </div>
                </div>
            `).join("");
        }

        function updateLatestComments(data){
            const commentbox = document.getElementById('latest-comment-box');
            if(!commentbox) return;

            if(!data || !data.length === 0){
                commentbox.innerHTML = `
                    <p class="text-muted mb-0">No comments yet.</p>
                `;
                return;
            }

            commentbox.innerHTML = data.map(comment=>`
                <div class="mb-3">
                    <strong>${ escapseHtml(comment.name) }</strong>
                    <p class="small mb-1">${ escapseHtml(comment.message) }</p>
                    <small class="small text-muted  d-block mb-3">
                        <i class="fa-regular fa-calendar"></i>
                        ${ comment.createdAt ? new Date(comment.createdAt).toLocaleDateString() : "" }
                    </small>
                </div>
            `).join("");
        }

        function updateTopLikedPosts(data){
            const tbody = document.getElementById('top-liked-posts-tbody');
            if(!tbody) return;

            if(!data || !data.length === 0){
                tbody.innerHTML = `
                    <tr>
                        <td colspan="4" class="text-muted">No Posts yet.</td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = data.map(post=>`
                <tr>
                    <td>
                        <div>${escapseHtml(post.title) }</div>
                        <small>${ post.createdAt ? new Date(post.createdAt).toLocaleDateString() : "" }</small>
                    </td>
                    <td>${ post.likesCount }</td>
                    <td>${ post.dislikesCount }</td>
                    <td>${ post.bookmarksCount }</td>
                </tr>
            `).join("");
        }

        // helper
        function escapseHtml(text){
            return String(text)
            .replaceAll("&","&amp;")
            .replaceAll("<","&lt;")
            .replaceAll(">","&gt;")
            .replaceAll('"',"&quot;")
            .replaceAll("'","&#39;");
        }
        


    </script>
</body>
</html>