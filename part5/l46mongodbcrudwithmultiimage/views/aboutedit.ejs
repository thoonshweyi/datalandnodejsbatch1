<!DOCTYPE html>
<html lang="en">
<%- include('./layout/head.ejs')  %>
<body>
    <%- include('./layout/nav.ejs')  %>

    <div class="container">
        <div>
            <h1>Edit About Page</h1>
            <% if(error){ %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
        </div>

        <div>
                <form action="/about/edit" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="" class="form-label">Page Title</label>
                        <!-- <input type="text" name="title" id="title" value="<%= aboutpage ? aboutpage.title : '' %>"> -->
                        <input type="text" name="title" id="title"  class="form-control" value="<%= aboutpage.title || '' %>">
                    </div>

                    <div class="mb-3">
                        <label for="body" class="form-label">About Body</label>
                        <textarea name="body" id="body"  class="form-control"><%= aboutpage ? aboutpage.body : '' %></textarea>
                    </div>


                    <div class="mb-3">
                        <label for="" class="form-label">Upload Multiple Images</label>
                        <input type="file" name="images" id="images" class="form-control" accept="image/*" multiple>
                        <div class="form-text">You can upload up to 5 images at once.</div>
                    </div>

                    
                    <% if(aboutpage.imageurls && aboutpage.imageurls.length > 0){ %>
                        <div class="row g-3 mb-3">

                            <% aboutpage.imageurls.forEach(imageurl =>{ %>
                                <div class="col-md-2">
                                    <img src="<%= imageurl %>" class="img-fluid rounded shadow-sm" alt="current image">
                                </div>
                            <% }) %>
                        
                        </div>
                    <% } %>
                 
                    <div class="d-flex justify-content-end gap-2">
                        <a href="/about" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>
                </form>
        </div>
    </div>


    
    <%- include('./layout/footer.ejs')  %>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>