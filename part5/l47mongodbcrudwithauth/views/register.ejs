<!DOCTYPE html>
<html lang="en">
<%- include('./layout/head.ejs')  %>
<body>
    <%- include('./layout/nav.ejs')  %>

    <div class="container mt-5" style="max-width: 500px;">
        <div>
            <h1>Register</h1>

            <% if(error){ %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
        </div>

        <div>
                <form action="/register" method="POST">
                    <div class="mb-3">
                        <label for="" class="form-label">User Name</label>
                        <!-- <input type="text" name="username" id="username" value="<%= formData ? formData.username : '' %>"> -->
                        <input type="text" name="username" id="username"  class="form-control" value="<%= %>">
                    </div>

                    <div class="mb-3">
                        <label for=" class="form-label"">Email</label>
                        <input type="email" name="email" id="email"  class="form-control" value="<%=  %>">
                    </div>

                    <div class="mb-3">
                        <label for=" class="form-label"">Password</label>
                        <input type="password" name="password" id="password"  class="form-control" value="<%=  %>">
                    </div>

                    <div class="mb-3">
                        <label for=" class="form-label"">Confirm Password</label>
                        <input type="password" name="cfmpassword" id="cfmpassword"  class="form-control" value="<%=  %>">
                    </div>
               
                    <div class="d-flex justify-content-end">
                        <button type="buttons" class="btn btn-primary">Register</button>
                    </div>
                    <a href="/login" class="btn btn-link">Already have account?</a>
                </form>
        </div>
    </div>


    
    <%- include('./layout/footer.ejs')  %>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>